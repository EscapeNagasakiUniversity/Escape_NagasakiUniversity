    'red', 'blue', 'yellow',
    'blue', 'red', 'red',
    'yellow', 'blue', 'blue'
]
E_LOCKER_COLOR_CYCLE: List[str] = ['red', 'blue', 'yellow']

# =========================================================
# entity パッケージ (エンティティ層)
# データ構造やモデルを定義するクラス群
# =========================================================

class Item:
    """各アイテムのデータ構造を保持するクラス"""
    def __init__(self, item_id: str, item_name: str, image_key: str, detail_image_key: str, description: str):
        self.item_id = item_id
        self.item_name = item_name
        self.image_key = image_key
        self.detail_image_key = detail_image_key
        self.description = description

class Gimmick:
    """ゲーム内のギミックの正誤状態や情報を管理するクラス"""
    def __init__(self, gimmick_id: str, correct: bool, correct_information: str):
        self.gimmick_id = gimmick_id
        self.correct = correct
        self.correct_information = correct_information

class RoomStage:
    """現在の部屋の位置、向き、ズーム状態を管理するクラス"""
    def __init__(self):
        self.directions: list[str] = ['N', 'E', 'S', 'W']
        self.current_dir_index: int = 0
        self.direction: str = self.directions[self.current_dir_index]
        self.current_room: int = 1
        self.zoom_state: Optional[str] = None

class Player:
    """プレイヤーの基本情報を保持するクラス"""
    def __init__(self, name: str = "西村想士郎"):
        self.name = name

class SaveData:
    """セーブデータの読み込みとファイル書き込みを管理するクラス"""
    def __init__(self):
        pass
    def _load_all_data(self) -> dict:
        if os.path.exists(SAVE_FILE_PATH):
            try:
                with open(SAVE_FILE_PATH, 'r', encoding='utf-8') as f:
                    return json.load(f)
            except Exception:
                pass
        return {"slot_1": None, "slot_2": None, "slot_3": None}
    def overwrite(self, item: Any, flag: bool) -> None:
        if flag and isinstance(item, tuple):
            slot_id, game_data = item
            all_data = self._load_all_data()
            all_data[slot_id] = game_data
            try:
                with open(SAVE_FILE_PATH, 'w', encoding='utf-8') as f:
                    json.dump(all_data, f, indent=4, ensure_ascii=False)
            except Exception as e:
                print(f"[Entity/SaveData] 保存エラー: {e}")
    def get_save_data(self, item: Any, flag: bool) -> Optional[dict]:
        if flag and isinstance(item, str):
            all_data = self._load_all_data()
            return all_data.get(item)
        return None

