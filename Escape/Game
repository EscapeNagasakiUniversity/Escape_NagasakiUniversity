    def arrow_identify(self, click_direction: str) -> None:
        """左右の矢印をクリックした際の視点切替を処理する"""
        if self.room_stage.current_room == 1 and not self.room_stage.zoom_state:
            if click_direction == 'right':
                self.room_stage.current_dir_index = (self.room_stage.current_dir_index + 1) % 4
            elif click_direction == 'left':
                self.room_stage.current_dir_index = (self.room_stage.current_dir_index - 1) % 4
            self.room_stage.direction = self.room_stage.directions[self.room_stage.current_dir_index]
            self.stage_page.confirm()

    def item_identify(self, item_id: str) -> None:
        """アイテムの詳細表示や合成処理を行う"""
        target_item = next((i for i in self.items if i.item_id == item_id), None)
        if target_item:
            if item_id == 'juice' and any(i.item_id == 'cutter' for i in self.items):
                self.items = [i for i in self.items if i.item_id not in ['juice', 'cutter']]
                self.items.append(Item('safe_key', ITEM_MASTER['safe_key']['name'], ITEM_MASTER['safe_key']['img'], ITEM_MASTER['safe_key']['detail'], ITEM_MASTER['safe_key']['desc']))
                self.selected_item_id = None
                self.stage_page.confirm()
                messagebox.showinfo("合成", "ジュースの缶をカッターで切り開き、中から「金庫の鍵」を取り出した！")
                return
            if item_id == 'remote' and any(i.item_id == 'battery' for i in self.items):
                self.items = [i for i in self.items if i.item_id not in ['remote', 'battery']]
                self.items.append(Item('remote_with_battery', ITEM_MASTER['remote_with_battery']['name'], ITEM_MASTER['remote_with_battery']['img'], ITEM_MASTER['remote_with_battery']['detail'], ITEM_MASTER['remote_with_battery']['desc']))
                self.selected_item_id = None
                self.stage_page.confirm()
                messagebox.showinfo("合成", "リモコンに電池をセットした！「電池入りリモコン」になった。")
                return

            self.room_stage.zoom_state = target_item.detail_image_key
            self.stage_page.confirm()

    def inventory_item_identify(self, item_id: str) -> None:
        """インベントリ内のアイテム選択処理"""
        self.selected_item_id = item_id
        self.inventory_page.confirm_emphasize()

    def get_data(self, item: Any, flag: bool) -> dict:
        """現在のゲーム状態を辞書形式で取得する（セーブ用）"""
        if flag:
            return {
                "room_stage": {
                    "current_room": self.room_stage.current_room,
                    "current_dir_index": self.room_stage.current_dir_index,
                    "direction": self.room_stage.direction,
                    "zoom_state": self.room_stage.zoom_state
                },
                "inventory": {
                    "items": [i.item_id for i in self.items],
                    "selected_item_id": self.selected_item_id
                },
                "gimmicks": {k: v.correct for k, v in self.gimmicks.items()},
                "e_locker_colors": self.e_locker_colors
            }
        return {}

    def reflect_data(self, item: Any, flag: bool) -> None:
        """保存されたデータをゲーム内に反映する（ロード用）"""
        if flag and isinstance(item, dict):
            room_data = item.get("room_stage", {})
            self.room_stage.current_room = room_data.get("current_room", 1)
            self.room_stage.current_dir_index = room_data.get("current_dir_index", 0)
            self.room_stage.direction = room_data.get("direction", 'N')
            self.room_stage.zoom_state = room_data.get("zoom_state", None)

            inv_data = item.get("inventory", {})
            saved_item_ids = inv_data.get("items", [])
            self.selected_item_id = inv_data.get("selected_item_id", None)
            
            self.items = []
            for item_id in saved_item_ids:
                if item_id in ITEM_MASTER:
                    master = ITEM_MASTER[item_id]
                    self.items.append(Item(item_id, master['name'], master['img'], master['detail'], master['desc']))

            gimmick_data = item.get("gimmicks", {})
            for g_id, is_correct in gimmick_data.items():
                if g_id in self.gimmicks:
                    self.gimmicks[g_id].correct = is_correct

            saved_colors = item.get("e_locker_colors", [None] * 9)
            if isinstance(saved_colors, list) and len(saved_colors) == 9:
                self.e_locker_colors = [color if color in E_LOCKER_COLOR_CYCLE else None for color in saved_colors]

            self.stage_page.confirm()

    def check(self, flag: bool, gimmick_id: str) -> bool:
        """特定のギミック（扉など）の解錠判定を行う"""
        if flag:
            if gimmick_id == 'room2_door':
                if self.selected_item_id == 'old_key':
                    self.gimmicks['room2_door'].correct = True
                    return True
            elif gimmick_id == 'exit_door':
                ans = simpledialog.askstring("脱出扉", "最終暗号を入力してください:")
                if ans == "ESCAPE": 
                    self.gimmicks['exit_door'].correct = True
                    return True
                elif ans is not None:
                    messagebox.showerror("エラー", "鍵は開かない。暗号を確認しよう。")
        return False

class SavedataManager:
    """セーブ・ロードの命令を統括するマネージャー"""
    def __init__(self, game_manager: GameManager):
        self.save_data = SaveData()
        self.game_manager = game_manager
        self.current_slot: str = "slot_1"

    def save_instruct(self) -> None:
        """現在の状態を指定スロットにセーブする"""
        current_state = self.game_manager.get_data(None, True)
        self.save_data.overwrite((self.current_slot, current_state), True)
        messagebox.showinfo("セーブ完了", f"{self.current_slot} にセーブしました。")

    def data_instruct(self, item: Any, flag: bool) -> None:
        """指定スロットからデータをロードする"""
        loaded_state = self.save_data.get_save_data(item, flag)
        if loaded_state:
            self.game_manager.reflect_data(loaded_state, True)
            messagebox.showinfo("ロード完了", f"{item} からロードしました。")
        else:
            messagebox.showwarning("ロード失敗", "データが存在しません。")


