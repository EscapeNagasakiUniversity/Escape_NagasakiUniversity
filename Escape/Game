    def reset_game(self) -> None:
        self.room_stage.current_room = 1
        self.room_stage.current_dir_index = 0
        self.room_stage.direction = self.room_stage.directions[0]
        self.room_stage.zoom_state = None
        self.selected_item_id = None
        self.items.clear()
        
        for gimmick in self.gimmicks.values():
            gimmick.correct = False

