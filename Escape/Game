class InventoryPage:
    def __init__(self, parent_frame: tk.Widget):
        self.parent_frame = parent_frame
        self.game_manager: Optional[GameManager] = None
        self._item_click_timer: Optional[str] = None
        
        self.item_buttons_frame = tk.Frame(parent_frame)
        self.item_buttons_frame.pack(side=tk.LEFT, padx=5)

    def set_manager(self, manager: GameManager) -> None:
        self.game_manager = manager

    def confirm_emphasize(self) -> None:
        for child in self.item_buttons_frame.winfo_children():
            child.destroy()

        if not self.game_manager:
            return

        for item in self.game_manager.items:
            is_selected = (self.game_manager.selected_item_id == item.item_id)
            bg_color = "lightblue" if is_selected else "lightgrey"
            relief_type = tk.SUNKEN if is_selected else tk.RAISED
            display_text = f"★ {item.item_name}" if is_selected else item.item_name

            btn = tk.Button(
                self.item_buttons_frame,
                text=display_text,
                bg=bg_color,
                relief=relief_type,
                command=lambda item_id=item.item_id: self._click_deferred(item_id)
            )
            btn.pack(side=tk.LEFT, padx=3)

    def _click_deferred(self, item_id: str) -> None:
        root = self.parent_frame.winfo_toplevel()
        if self._item_click_timer is not None:
            root.after_cancel(self._item_click_timer)
            self._item_click_timer = None
            self._double_click(item_id)
        else:
            self._item_click_timer = root.after(250, lambda: self._execute_single_click(item_id))

    def _execute_single_click(self, item_id: str) -> None:
        self._item_click_timer = None
        if self.game_manager:
            self.game_manager.inventory_item_identify(item_id)

    def _double_click(self, item_id: str) -> None:
        if self.game_manager:
            self.game_manager.item_identify(item_id)


