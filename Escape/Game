class SavedataListPage:
    def __init__(self, root: tk.Tk, savedata_manager: SavedataManager):
        self.root = root
        self.savedata_manager = savedata_manager
        self.window: Optional[tk.Toplevel] = None

    def confirm(self) -> None:
        if self.window is not None and self.window.winfo_exists():
            self.window.lift()
            return

        self.window = tk.Toplevel(self.root)
        self.window.title("セーブデータ一覧")
        self.window.geometry("350x250")
        self.window.grab_set()

        title_label = tk.Label(self.window, text="セーブデータを選択してください", pady=10, font=("", 12))
        title_label.pack()

        all_data = self.savedata_manager.save_data._load_all_data()

        for i in range(1, 4):
            slot_id = f"slot_{i}"
            has_data = all_data.get(slot_id) is not None
            status_text = "データあり" if has_data else "No Data"

            frame = tk.Frame(self.window, pady=5)
            frame.pack(fill=tk.X, padx=20)

            lbl = tk.Label(frame, text=f"スロット {i} : {status_text}", width=15, anchor="w")
            lbl.pack(side=tk.LEFT)

            save_btn = tk.Button(frame, text="セーブ", command=lambda sid=slot_id: self.select(sid, "save"))
            save_btn.pack(side=tk.RIGHT, padx=5)

            load_state = tk.NORMAL if has_data else tk.DISABLED
            load_btn = tk.Button(frame, text="ロード", state=load_state, command=lambda sid=slot_id: self.select(sid, "load"))
            load_btn.pack(side=tk.RIGHT, padx=5)

    def select(self, item_id: str, action: str = "load") -> None:
        if action == "save":
            self.savedata_manager.current_slot = item_id
            self.savedata_manager.save_instruct()
            if self.window:
                self.window.destroy()
        elif action == "load":
            self.savedata_manager.data_instruct(item_id, True)
            if self.window:
                self.window.destroy()

