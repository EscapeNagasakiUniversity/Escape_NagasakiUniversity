# 添字はモニター番号(=自販機パネル番号)で、0〜8が3x3の左上から右下に対応する。
# =========================================================
MONITOR_LIGHT_SEQUENCE: List[int] = [0, 1, 2, 5, 8, 7, 6, 3, 4]

# N面にあるロッカーの配色。Eロッカーの9マスをこの順に合わせると解錠される。
