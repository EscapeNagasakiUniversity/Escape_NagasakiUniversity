    """ゲーム全体の進行状態やプレイヤーのアクションを制御するマネージャー"""
    def __init__(self, room_stage: RoomStage, player: Player, inventory_page: Any, stage_page: Any):
        self.room_stage = room_stage
        self.player = player
        self.inventory_page = inventory_page
        self.stage_page = stage_page
        self.items: List[Item] = []
        self.selected_item_id: Optional[str] = None
        
        self.vending_correct_sequence = list(MONITOR_LIGHT_SEQUENCE)
        self.vending_current_input = []
        # None は未選択（白）。各マスはクリックごとに赤→青→黄→赤と変わる。
        self.e_locker_colors: List[Optional[str]] = [None] * 9

        # ギミックの初期状態定義
        self.gimmicks: Dict[str, Gimmick] = {
            'exit_door': Gimmick('exit_door', False, '脱出扉が開いた。'),
            'room2_door': Gimmick('room2_door', False, 'もう一つの部屋への扉が開いた。'),
            'e_locker': Gimmick('e_locker', False, 'Eロッカー解錠'),
            'safe': Gimmick('safe', False, '金庫解錠'),
            'vending_power': Gimmick('vending_power', False, '自販機通電(謎解きクリア)'),
            'pc_boot': Gimmick('pc_boot', False, 'パソコン起動'),
            'pc_login': Gimmick('pc_login', False, 'パソコンログイン成功'),
            'projector': Gimmick('projector', False, 'プロジェクター起動'),
            'planter_n': Gimmick('planter_n', False, 'Nプランター捜索済'),
            'planter_e': Gimmick('planter_e', False, 'Eプランター捜索済'),
            'planter_s': Gimmick('planter_s', False, 'Sプランター捜索済'),
            'planter_w': Gimmick('planter_w', False, 'Wプランター捜索済'),
            'got_broom': Gimmick('got_broom', False, 'ほうき取得済'),
            'got_remote': Gimmick('got_remote', False, 'リモコン取得済'),
            'got_shovel': Gimmick('got_shovel', False, 'シャベル取得済'),
            'got_coin': Gimmick('got_coin', False, 'コイン取得済'),
            'got_charger': Gimmick('got_charger', False, '充電器取得済'),
            'got_battery': Gimmick('got_battery', False, '電池取得済'),
            'monitors_flashed': Gimmick('monitors_flashed', True, 'モニター常時点灯')
        }
        self.reset_game()

    def reset_game(self) -> None:
        """ゲームの状態を初期化する"""
        self.room_stage.current_room = 1
        self.room_stage.current_dir_index = 0
        self.room_stage.direction = self.room_stage.directions[0]
        self.room_stage.zoom_state = None
        self.selected_item_id = None
        self.items.clear()
        self.vending_current_input.clear()
        self.e_locker_colors = [None] * 9
        for gimmick_id, gimmick in self.gimmicks.items():
            if gimmick_id == 'monitors_flashed':
                gimmick.correct = True
            else:
                gimmick.correct = False

    def object_identify(self, target_id: str) -> None:
        """クリックされたオブジェクトに応じたイベントや謎解き処理を実行する"""
        if target_id == 'n_locker':
            self.room_stage.zoom_state = 'n_locker_detail.png'
            self.stage_page.confirm()
        elif target_id == 'get_broom':
            if not self.gimmicks['got_broom'].correct:
                self.items.append(Item('broom', ITEM_MASTER['broom']['name'], ITEM_MASTER['broom']['img'], ITEM_MASTER['broom']['detail'], ITEM_MASTER['broom']['desc']))
                self.gimmicks['got_broom'].correct = True
                self.stage_page.confirm()
                messagebox.showinfo("発見", "「ほうき」を手に入れた！")
            else:
                messagebox.showinfo("調査", "そこにはもう何もない。")
        elif target_id == 'get_remote':
            if not self.gimmicks['got_remote'].correct:
                self.items.append(Item('remote', ITEM_MASTER['remote']['name'], ITEM_MASTER['remote']['img'], ITEM_MASTER['remote']['detail'], ITEM_MASTER['remote']['desc']))
                self.gimmicks['got_remote'].correct = True
                self.stage_page.confirm()
                messagebox.showinfo("発見", "「リモコン」を手に入れた！")
            else:
                messagebox.showinfo("調査", "そこにはもう何もない。")

        elif target_id == 'e_locker':
            self.room_stage.zoom_state = (
                'e_locker_contents.png' if self.gimmicks['e_locker'].correct
                else 'e_locker_detail.png'
            )
            self.stage_page.confirm()
        elif target_id == 'e_locker_puzzle':
            self.room_stage.zoom_state = 'e_locker_puzzle.png'
            self.stage_page.confirm()
        elif target_id.startswith('e_locker_cell_'):
            if self.gimmicks['e_locker'].correct:
                self.room_stage.zoom_state = 'e_locker_contents.png'
                self.stage_page.confirm()
                return

            index = int(target_id.rsplit('_', 1)[-1])
            current_color = self.e_locker_colors[index]
            next_index = (E_LOCKER_COLOR_CYCLE.index(current_color) + 1) % len(E_LOCKER_COLOR_CYCLE) if current_color else 0
            self.e_locker_colors[index] = E_LOCKER_COLOR_CYCLE[next_index]

            if self.e_locker_colors == E_LOCKER_CORRECT_COLORS:
                self.gimmicks['e_locker'].correct = True
                self.room_stage.zoom_state = 'e_locker_contents.png'
                self.stage_page.confirm()
                messagebox.showinfo("成功", "N面のロッカーと同じ配色だ。Eロッカーが開いた！")
            else:
                self.stage_page.confirm()
        elif target_id == 'get_battery':
            if not self.gimmicks['got_battery'].correct:
                self.items.append(Item('battery', ITEM_MASTER['battery']['name'], ITEM_MASTER['battery']['img'], ITEM_MASTER['battery']['detail'], ITEM_MASTER['battery']['desc']))
                self.gimmicks['got_battery'].correct = True
                self.stage_page.confirm()
                messagebox.showinfo("発見", "「電池」を手に入れた！")
            else:
                messagebox.showinfo("調査", "ロッカーの中はもう空だ。")

        elif target_id == 'projector':
            if self.gimmicks['projector'].correct:
                messagebox.showinfo("プロジェクター", "プロジェクターは稼働中です。ホワイトボードに画像が映し出されています。")
            elif self.selected_item_id == 'remote_with_battery':
                self.gimmicks['projector'].correct = True
                messagebox.showinfo("起動", "電池入りリモコンでプロジェクターが起動した！ホワイトボードに暗号が浮かび上がる。")
            else:
                messagebox.showinfo("確認", "電源が入っていない。動かす方法がありそうだ。")
        elif target_id == 'whiteboard':
            if self.gimmicks['projector'].correct:
                messagebox.showinfo("ホワイトボード", "ホワイトボードにモニターが光る順番のヒントが表示されている！")
            else:
                messagebox.showinfo("ホワイトボード", "何も映っていない。白紙のホワイトボードだ。")

        elif target_id == 'vending_machine':
            if not self.gimmicks['vending_power'].correct:
                self.room_stage.zoom_state = 'S-自販機-謎.png'
            else:
                self.room_stage.zoom_state = 'vending_detail.png'
            self.stage_page.confirm()
        elif target_id == 'vending_padlock':
            messagebox.showinfo("自販機", "鍵はかかっていない。謎を解いて電源を入れる必要がある。")
        elif target_id == 'vending_coin_slot':
            if not self.gimmicks['vending_power'].correct:
                messagebox.showinfo("自販機", "電源が入っていない。まずは自販機の下の謎を解く必要がある。")
            elif self.selected_item_id == 'coin_100':
                if not any(i.item_id == 'juice' for i in self.items):
                    self.items = [i for i in self.items if i.item_id != 'coin_100']
                    self.items.append(Item('juice', ITEM_MASTER['juice']['name'], ITEM_MASTER['juice']['img'], ITEM_MASTER['juice']['detail'], ITEM_MASTER['juice']['desc']))
                    self.selected_item_id = None
                    self.stage_page.confirm()
                    messagebox.showinfo("購入", "ガチャ！冷えた「ジュース」が出てきた！")
            else:
                messagebox.showinfo("自販機", "100円玉を選択して投入してください。")
        elif target_id == 'vending_bottom':
            if not any(i.item_id == 'cutter' for i in self.items):
