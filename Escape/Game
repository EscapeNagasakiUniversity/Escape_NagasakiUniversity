            target_h = 348 - 54   # pc_login_detail.png の画面高さ
            panel_resized = panel.resize((target_w, target_h))
            self.pc_password_overlay = ImageTk.PhotoImage(panel_resized)
        except Exception:
            self.pc_password_overlay = None

    def set_managers(self, game_manager: GameManager, savedata_list_page: SavedataListPage, menu_page: MenuPage) -> None:
        self.game_manager = game_manager
        self.savedata_list_page = savedata_list_page
        self.menu_page = menu_page

    def _cancel_monitor_animation(self) -> None:
        """実行中のモニター順次点灯アニメーションタイマーがあればキャンセルする"""
        if self.monitor_anim_job is not None:
            try:
                self.parent_frame.after_cancel(self.monitor_anim_job)
            except Exception:
                pass
            self.monitor_anim_job = None

    def _animate_monitors(self) -> None:
        """Room 2において、モニターを順番に光らせるアニメーションループ処理"""
        if self.room_stage.current_room == 2 and not self.room_stage.zoom_state:
            # 次に光らせるモニターのインデックスを更新
            self.current_lit_monitor_index = (self.current_lit_monitor_index + 1) % len(self.monitor_sequence)
            self.confirm()  # 画面を再描画して現在の点灯状態を反映
            # 400ミリ秒ごとに次のモニターへ切り替え
            self.monitor_anim_job = self.parent_frame.after(400, self._animate_monitors)

    def confirm(self) -> None:
        """画面を更新し、現在のステージ状態やモニターの発光状態を描画する"""
        if self.menu_page:
            self.menu_page.parent_frame.pack_forget()
        self.parent_frame.pack(expand=True, fill=tk.BOTH)

        # 部屋がRoom 2以外に変わった場合はアニメーションを停止する
        if self.room_stage.current_room != 2:
            self._cancel_monitor_animation()

        img_key = self.room_stage.zoom_state if self.room_stage.zoom_state else (
            self.room_stage.direction if self.room_stage.current_room == 1 else 'room2'
        )

        if self.canvas_wall_id is not None:
            self.canvas.delete("all") 

        self.canvas_wall_id = self.canvas.create_image(0, 0, image=self.images.get(img_key, tk.PhotoImage()), anchor=tk.NW)

        # PCが起動済みでまだログインしていない間は、画面部分にパスワード入力画面を重ねて隠す
        if (self.room_stage.zoom_state == 'pc_login_detail.png' and self.game_manager
                and not self.game_manager.gimmicks['pc_login'].correct):
            if self.pc_password_overlay:
                ox, oy = self.pc_password_overlay_pos
                self.canvas.create_image(ox, oy, image=self.pc_password_overlay, anchor=tk.NW)
            else:
                # Pillowが無い等の理由で切り出し画像が用意できない場合のフォールバック。
                # サンプル画像をそのまま画面部分の左上に重ねて表示する（サイズは調整されない）。
                fallback_img = self.images.get('pc_password_sample.png')
                if fallback_img and fallback_img.width() > 1:
                    ox, oy = self.pc_password_overlay_pos
                    self.canvas.create_image(ox, oy, image=fallback_img, anchor=tk.NW)

        # プロジェクター起動後は、E面のホワイトボード部分に暗号画像を表示する。
        if (self.room_stage.current_room == 1 and self.room_stage.direction == 'E'
                and not self.room_stage.zoom_state and self.game_manager
                and self.game_manager.gimmicks['projector'].correct):
            projected_img = self.images.get('whiteboard_projected.png')
            if projected_img and projected_img.width() > 1:
                self.canvas.create_image(228, 73, image=projected_img, anchor=tk.NW)

        current_state_key = (self.room_stage.current_room, self.room_stage.direction, self.room_stage.zoom_state)
        layout_list = STAGE_LAYOUT.get(current_state_key, [])
        marker_img = self.images.get('marker.png')
        light_img = self.images.get('light.png')

        for layout in layout_list:
            rx1, ry1, rx2, ry2 = layout['rect']
            target_id = layout['target']

            # Keep the source grid visible and fill only the inside of each E-locker cell.
            is_e_locker_cell = isinstance(target_id, str) and target_id.startswith('e_locker_cell_')
            if is_e_locker_cell:
                cell_index = int(layout['target'].rsplit('_', 1)[-1])
                cell_color = self.game_manager.e_locker_colors[cell_index] if self.game_manager else None
                self.canvas.create_rectangle(
                    rx1 + 4, ry1 + 4, rx2 - 4, ry2 - 4,
                    fill=cell_color or 'white', outline=''
                )
                continue

            # 投影中はホワイトボードのクリック目印を表示せず、暗号画像を見せる。
            is_projected_whiteboard = (
                target_id == 'whiteboard' and self.game_manager
                and self.game_manager.gimmicks['projector'].correct
            )
            if is_projected_whiteboard:
                continue
            
            # Room 2のモニター判定：順番に沿ってアクティブになっているモニターを光らせる
            is_monitors_screen = (
                self.room_stage.current_room == 2 and isinstance(target_id, str)
                and target_id.startswith('monitor_')
            )
            lit_up = False
            if is_monitors_screen and self.game_manager:
                if self.game_manager.gimmicks['monitors_flashed'].correct:
                    # 現在のアニメーションステップで該当するモニター番号と一致するか判定
                    target_monitor_id = int(layout['target'].split('_')[-1])
                    current_active_seq_val = self.monitor_sequence[self.current_lit_monitor_index]
                    if target_monitor_id == current_active_seq_val:
                        lit_up = True

            if lit_up and light_img and light_img.width() > 1:
                # light.png内の光る矩形の中心を、このモニター画面の中心に合わせて描画する。
                # (rx1, ry1)にそのまま描画すると、light.png内部の矩形オフセット分
                # さらにズレてしまうため、中心合わせで補正する。
                screen_center_x = (rx1 + rx2) / 2
                screen_center_y = (ry1 + ry2) / 2
                draw_x = screen_center_x - self._light_content_center[0]
                draw_y = screen_center_y - self._light_content_center[1]
                self.canvas.create_image(draw_x, draw_y, image=light_img, anchor=tk.NW)
            elif marker_img and marker_img.width() > 1 and not is_monitors_screen:
                self.canvas.create_image(rx1, ry1, image=marker_img, anchor=tk.NW)
            elif not is_monitors_screen:
                self.canvas.create_rectangle(
                    rx1, ry1, rx2, ry2,
                    outline="yellow",  
                    width=2,           
                    dash=(4, 4)
                )

        if self.room_stage.zoom_state:
            self.left_button.pack_forget()
            self.right_button.pack_forget()
            self.exit_button.pack_forget()
            self.back_button.pack(side=tk.LEFT)
        elif self.room_stage.current_room == 1:
            self.back_button.pack_forget()
            self.exit_button.pack_forget()
            self.left_button.pack(side=tk.LEFT)
            self.right_button.pack(side=tk.RIGHT)
        else:
            self.left_button.pack_forget()
            self.right_button.pack_forget()
            self.back_button.pack_forget()
            self.exit_button.pack(side=tk.LEFT)

        self.inventory_page.confirm_emphasize()

    def _open_savedata_page(self) -> None:
        if self.savedata_list_page:
            self.savedata_list_page.confirm()

    def _return_to_title(self) -> None:
        if messagebox.askyesno("確認", "タイトル画面に戻りますか？\nセーブしていない進行状況は失われます。"):
            self._cancel_monitor_animation()
            if self.menu_page:
                self.menu_page.confirm()

    def _arrow_click(self, direction: str) -> None:
        if self.game_manager:
            self.game_manager.arrow_identify(direction)

    def _exit_click(self) -> None:
        if self.room_stage.zoom_state:
            return
        if self.room_stage.current_room == 2:
            self._cancel_monitor_animation()
            self.room_stage.current_room = 1
            self.room_stage.direction = 'S'
            self.room_stage.current_dir_index = 2
            self.confirm()

    def _arrow_click_left(self) -> None:
        self._arrow_click('left')

    def _arrow_click_right(self) -> None:
        self._arrow_click('right')

    def _back_click(self) -> None:
        self.room_stage.zoom_state = None
        self.confirm()
        # ズーム解除してRoom2に戻った場合、アニメーションが停止していれば再開する
        if self.room_stage.current_room == 2 and self.monitor_anim_job is None:
            self._animate_monitors()

    def _get_clicked_target(self, x: int, y: int) -> Optional[dict]:
        current_state_key = (self.room_stage.current_room, self.room_stage.direction, self.room_stage.zoom_state)
        layout_list = STAGE_LAYOUT.get(current_state_key, [])
        for layout in layout_list:
            rx1, ry1, rx2, ry2 = layout['rect']
            if rx1 <= x <= rx2 and ry1 <= y <= ry2:
                return layout
        return None

    def _on_canvas_click(self, event: tk.Event) -> None:
        target_data = self._get_clicked_target(event.x, event.y)
        if not target_data:
            return

        action_type = target_data['type']
        target_val = target_data['target']

        if action_type == 'door':
            if self.game_manager:
                if target_val == 2:
                    # 部屋2へ移る際、扉に定義された target_dir に向きを合わせる。
                    # これを行わないと room_stage.direction が 'S' のまま残り、
                    # STAGE_LAYOUT の (2, 'N', None) キーと一致せず
                    # モニターの当たり判定が一切取得できなくなるバグがあった。
                    new_dir = target_data.get('target_dir', 'N')
                    if self.game_manager.gimmicks['room2_door'].correct:
                        self.room_stage.current_room = 2
                        self.room_stage.direction = new_dir
                        self.room_stage.zoom_state = None
                        self.confirm()
                        # Room 2に入った瞬間にモニターの順次点灯アニメーションを開始
                        self._animate_monitors()
                    else:
                        success = self.game_manager.check(True, 'room2_door')
                        if success:
                            self.room_stage.current_room = 2
                            self.room_stage.direction = new_dir
                            self.room_stage.zoom_state = None
                            self.confirm()
                            # Room 2に入った瞬間にモニターの順次点灯アニメーションを開始
                            self._animate_monitors()
                            messagebox.showinfo("扉", "古い鍵で扉が開き、もう一つの部屋に入った！")
                        else:
                            messagebox.showinfo("扉", "鍵がかかっている。インベントリから「古い鍵」を選択した状態で扉を調べてください。")
                else:
                    self._cancel_monitor_animation()
                    self.room_stage.current_room = target_val
                    self.confirm()

        elif action_type in ('object', 'zoom_action'):
            if self.game_manager:
                # ズームに入る際はアニメーションを一旦停止
                if target_val.startswith('monitor_'):
                    pass
                self.game_manager.object_identify(target_val)

        elif action_type == 'gimmick_door':
            if self.game_manager:
                success = self.game_manager.check(True, target_val)
                if success:
                    self._cancel_monitor_animation()
                    player_name = self.game_manager.player.name
                    messagebox.showinfo("ゲームクリア", f"おめでとうございます！\n暗号を解き明かし、{player_name}は無事に脱出に成功しました！")
                    self.parent_frame.winfo_toplevel().destroy()

    def _on_canvas_mouse_move(self, event: tk.Event) -> None:
        target_data = self._get_clicked_target(event.x, event.y)
        if target_data:
            self.canvas.config(cursor="hand2")
        else:
            self.canvas.config(cursor="")

